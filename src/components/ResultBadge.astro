---
import { resultClass, resultLabel } from '../lib/stats';
type R = 'W' | 'D' | 'L';
interface Props {
  r: R;
  size?: 'sm' | 'base';
}
const { r, size = 'sm' } = Astro.props;
const sizeClass = size === 'base' ? 'text-sm px-3 py-1' : 'text-xs px-2 py-0.5';
---

<span class={`font-bold rounded ${sizeClass} ${resultClass(r)}`}>
  {resultLabel(r)}
</span>
